    {
      "id": "f9_desc_t",
      "type": "text",
      "x": 4640,
      "y": 2978.75,
      "width": 630,
      "height": 162.5,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3z",
      "roundness": null,
      "seed": 200286,
      "version": 1,
      "versionNonce": 200287,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Purpose\n\nEnable passengers to browse routes,\nstops, and schedules without network.\nDrivers can continue tracking trips\noffline with location queue that\nsyncs when connectivity returns.\n\nCritical for areas with poor\nmobile network coverage.",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "f9_desc",
      "originalText": "Purpose\n\nEnable passengers to browse routes,\nstops, and schedules without network.\nDrivers can continue tracking trips\noffline with location queue that\nsyncs when connectivity returns.\n\nCritical for areas with poor\nmobile network coverage.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "f9_impl",
      "type": "rectangle",
      "x": 5300,
      "y": 2950,
      "width": 1310,
      "height": 220,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "#f1f3f5",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b40",
      "roundness": {
        "type": 3
      },
      "seed": 200288,
      "version": 1,
      "versionNonce": 200289,
      "isDeleted": false,
      "boundElements": [
        {
          "type": "text",
          "id": "f9_impl_t"
        }
      ],
      "updated": 1,
      "link": null,
      "locked": false
    },
    {
      "id": "f9_impl_t",
      "type": "text",
      "x": 5310,
      "y": 2962.5,
      "width": 1290,
      "height": 195,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b41",
      "roundness": null,
      "seed": 200290,
      "version": 1,
      "versionNonce": 200291,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Implementation Plan\n\nMobile storage: expo-sqlite or WatermelonDB\n  Cache: routes, stops, route_stops (read-only sync)\n  Queue: location updates for offline trips\n\nSync strategy:\n  Background sync on connectivity change (NetInfo)\n  Conflict resolution: server timestamp wins\n  Delta sync: only changed records since lastSync\n\nDriver: Location queue with expo-file-system\n  Replay queued locations on reconnect",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "f9_impl",
      "originalText": "Implementation Plan\n\nMobile storage: expo-sqlite or WatermelonDB\n  Cache: routes, stops, route_stops (read-only sync)\n  Queue: location updates for offline trips\n\nSync strategy:\n  Background sync on connectivity change (NetInfo)\n  Conflict resolution: server timestamp wins\n  Delta sync: only changed records since lastSync\n\nDriver: Location queue with expo-file-system\n  Replay queued locations on reconnect",
      "autoResize": true,
      "lineHeight": 1.25
    },
