    {
      "id": "m5_data_t",
      "type": "text",
      "x": 760,
      "y": 1622.5,
      "width": 630,
      "height": 195,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
