    {
      "id": "m6_tech_t",
      "type": "text",
      "x": 1430,
      "y": 1965,
      "width": 670,
      "height": 210,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1k",
      "roundness": null,
      "seed": 200112,
      "version": 1,
      "versionNonce": 200113,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Technical Implementation\n\nFiles: demo.service.ts, demo.routes.ts\n\nAPI:\n  POST /demo/start  (admin only)\n  POST /demo/stop   (admin only)\n  GET  /demo/status (public)\n\nIntegration:\n  Same Redis pipeline as real tracking\n  Same Socket.IO broadcast channels\n  Clients see demo buses identically\n  to real ones",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m6_tech",
      "originalText": "Technical Implementation\n\nFiles: demo.service.ts, demo.routes.ts\n\nAPI:\n  POST /demo/start  (admin only)\n  POST /demo/stop   (admin only)\n  GET  /demo/status (public)\n\nIntegration:\n  Same Redis pipeline as real tracking\n  Same Socket.IO broadcast channels\n  Clients see demo buses identically\n  to real ones",
      "autoResize": true,
      "lineHeight": 1.25
    },
