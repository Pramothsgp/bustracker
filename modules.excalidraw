      "link": null,
      "locked": false
    },
    {
      "id": "m7_desc_t",
      "type": "text",
      "x": 140,
      "y": 2335,
      "width": 960,
      "height": 130,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1p",
      "roundness": null,
      "seed": 200122,
      "version": 1,
      "versionNonce": 200123,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Purpose & Overview\n\nProvides all distance and proximity calculations without PostGIS.\nCombines Haversine formula (server-side JS) with Redis GEORADIUS\n(for real-time bus positions). Handles coordinate-based filtering\nfor stops, buses, and nearby queries.\n\nCenter point: Coimbatore (11.0168°N, 76.9558°E)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m7_desc",
      "originalText": "Purpose & Overview\n\nProvides all distance and proximity calculations without PostGIS.\nCombines Haversine formula (server-side JS) with Redis GEORADIUS\n(for real-time bus positions). Handles coordinate-based filtering\nfor stops, buses, and nearby queries.\n\nCenter point: Coimbatore (11.0168°N, 76.9558°E)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "m7_tech",
      "type": "rectangle",
      "x": 1130,
      "y": 2290,
      "width": 980,
      "height": 220,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "#f1f3f5",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1q",
      "roundness": {
        "type": 3
      },
