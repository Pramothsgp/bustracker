      "updated": 1,
      "link": null,
      "locked": false
    },
    {
      "id": "m6_desc_t",
      "type": "text",
      "x": 140,
      "y": 1996.875,
      "width": 580,
      "height": 146.25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1g",
      "roundness": null,
      "seed": 200104,
      "version": 1,
      "versionNonce": 200105,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Purpose & Overview\n\nServer-side virtual bus simulation\nfor testing and demonstration.\nCreates virtual buses that move\nalong real routes at 30 km/h,\ninterpolating between geocoded\nstops. Up to 10 routes simulated\nsimultaneously.",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m6_desc",
      "originalText": "Purpose & Overview\n\nServer-side virtual bus simulation\nfor testing and demonstration.\nCreates virtual buses that move\nalong real routes at 30 km/h,\ninterpolating between geocoded\nstops. Up to 10 routes simulated\nsimultaneously.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "m6_data",
      "type": "rectangle",
      "x": 750,
      "y": 1940,
      "width": 650,
      "height": 260,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "#fff9db",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1h",
      "roundness": {
        "type": 3
      },
      "seed": 200106,
      "version": 1,
      "versionNonce": 200107,
      "isDeleted": false,
      "boundElements": [
        {
          "type": "text",
          "id": "m6_data_t"
        }
      ],
      "updated": 1,
      "link": null,
      "locked": false
    },
    {
      "id": "m6_data_t",
      "type": "text",
      "x": 760,
      "y": 1972.5,
      "width": 630,
      "height": 195,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1i",
      "roundness": null,
      "seed": 200108,
      "version": 1,
      "versionNonce": 200109,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Simulation Algorithm\n\nTick interval: 10 seconds\nSpeed: 30 km/h (configurable)\n\nPer tick:\n  distance = (30/3600) × 10 = 0.083 km\n  progress = distance / segmentLength\n  newLat = lat1 + (lat2-lat1) × progress\n  newLng = lng1 + (lng2-lng1) × progress\n\nWhen progress ≥ 1.0 → advance to next\nstop pair, wraps around at route end",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m6_data",
      "originalText": "Simulation Algorithm\n\nTick interval: 10 seconds\nSpeed: 30 km/h (configurable)\n\nPer tick:\n  distance = (30/3600) × 10 = 0.083 km\n  progress = distance / segmentLength\n  newLat = lat1 + (lat2-lat1) × progress\n  newLng = lng1 + (lng2-lng1) × progress\n\nWhen progress ≥ 1.0 → advance to next\nstop pair, wraps around at route end",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
