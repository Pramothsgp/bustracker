    },
    {
      "id": "m7_desc",
      "type": "rectangle",
      "x": 130,
      "y": 2290,
      "width": 980,
      "height": 220,
      "angle": 0,
      "strokeColor": "#e67700",
      "backgroundColor": "#fff3bf",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1o",
      "roundness": {
        "type": 3
      },
