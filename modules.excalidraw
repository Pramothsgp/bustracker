    {
      "id": "m9_tech_t",
      "type": "text",
      "x": 1140,
      "y": 2982.5,
      "width": 960,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b25",
      "roundness": null,
      "seed": 200154,
      "version": 1,
      "versionNonce": 200155,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Technical Implementation\n\nFiles: background-location.ts, trip/active.tsx\n\nexpo-task-manager:\n  TaskManager.defineTask(TASK_NAME, callback)\n  Must be defined at module level (Expo requirement)\n  globalThis.__activeTripId for cross-scope access\n\nFallback Strategy:\n  If background unavailable → foreground watchPosition\n  Location.watchPositionAsync with same config\n  Works in Expo Go (no native module needed)\n\nSocket.IO emit: location:update {lat, lng, speed, heading}",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m9_tech",
      "originalText": "Technical Implementation\n\nFiles: background-location.ts, trip/active.tsx\n\nexpo-task-manager:\n  TaskManager.defineTask(TASK_NAME, callback)\n  Must be defined at module level (Expo requirement)\n  globalThis.__activeTripId for cross-scope access\n\nFallback Strategy:\n  If background unavailable → foreground watchPosition\n  Location.watchPositionAsync with same config\n  Works in Expo Go (no native module needed)\n\nSocket.IO emit: location:update {lat, lng, speed, heading}",
      "autoResize": true,
      "lineHeight": 1.25
    },
