    {
      "id": "m3_desc_t",
      "type": "text",
      "x": 140,
      "y": 946.875,
      "width": 580,
      "height": 146.25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0p",
      "roundness": null,
      "seed": 200050,
      "version": 1,
      "versionNonce": 200051,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Purpose & Overview\n\nManages 569 bus stops with\ngeocoded coordinates (~284 with\nlat/lng). Provides proximity-based\nsearch using the Haversine formula\nto find nearby stops within a\nconfigurable radius (default 2km,\nmax 10km).",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m3_desc",
      "originalText": "Purpose & Overview\n\nManages 569 bus stops with\ngeocoded coordinates (~284 with\nlat/lng). Provides proximity-based\nsearch using the Haversine formula\nto find nearby stops within a\nconfigurable radius (default 2km,\nmax 10km).",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "m3_data",
      "type": "rectangle",
      "x": 750,
      "y": 890,
      "width": 650,
