      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Technical Implementation\n\nFiles: tracking.service.ts, socket.ts\n       tracking.routes.ts\n\nSocket.IO /tracking namespace\n  Rooms: route:{id}, trip:{id}, nearby\n\nRedis Commands:\n  GEOADD active_buses lng lat tripId\n  GEORADIUS active_buses lng lat radius\n  HSET/HGET bus:{tripId} metadata (5min TTL)",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m1_tech",
      "originalText": "Technical Implementation\n\nFiles: tracking.service.ts, socket.ts\n       tracking.routes.ts\n\nSocket.IO /tracking namespace\n  Rooms: route:{id}, trip:{id}, nearby\n\nRedis Commands:\n  GEOADD active_buses lng lat tripId\n  GEORADIUS active_buses lng lat radius\n  HSET/HGET bus:{tripId} metadata (5min TTL)",
      "autoResize": true,
      "lineHeight": 1.25
    },
