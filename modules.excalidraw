    {
      "id": "m3_data_t",
      "type": "text",
      "x": 760,
      "y": 930,
      "width": 630,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0r",
      "roundness": null,
      "seed": 200054,
      "version": 1,
      "versionNonce": 200055,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Data Retrieval & Geospatial Logic\n\nGET /stops           → All stops\nGET /stops/:id       → Stop + passing routes\nGET /stops/nearby    → Haversine filtered\n  ?lat=11.01&lng=76.95&radius=2\n\nHaversine Formula:\n  a = sin²(Δlat/2) + cos(lat1)·cos(lat2)\n      · sin²(Δlng/2)\n  d = 2R · atan2(√a, √(1-a))\n  R = 6371 km (Earth radius)",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m3_data",
      "originalText": "Data Retrieval & Geospatial Logic\n\nGET /stops           → All stops\nGET /stops/:id       → Stop + passing routes\nGET /stops/nearby    → Haversine filtered\n  ?lat=11.01&lng=76.95&radius=2\n\nHaversine Formula:\n  a = sin²(Δlat/2) + cos(lat1)·cos(lat2)\n      · sin²(Δlng/2)\n  d = 2R · atan2(√a, √(1-a))\n  R = 6371 km (Earth radius)",
      "autoResize": true,
      "lineHeight": 1.25
    },
