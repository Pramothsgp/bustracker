    {
      "id": "m1_data_t",
      "type": "text",
      "x": 760,
      "y": 257.5,
      "width": 630,
      "height": 165,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b09",
      "roundness": null,
      "seed": 200018,
      "version": 1,
      "versionNonce": 200019,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Data Flow\n\nINPUT:  GPS coordinates (lat, lng, speed,\n        heading, accuracy) every 10 seconds\n\nPROCESS: Redis GEOADD for spatial indexing\n         HSET bus:{tripId} for metadata\n         Buffer → DB flush every 30 seconds\n\nOUTPUT:  bus:moved broadcast to all clients\n         bus:position to specific trackers",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m1_data",
      "originalText": "Data Flow\n\nINPUT:  GPS coordinates (lat, lng, speed,\n        heading, accuracy) every 10 seconds\n\nPROCESS: Redis GEOADD for spatial indexing\n         HSET bus:{tripId} for metadata\n         Buffer → DB flush every 30 seconds\n\nOUTPUT:  bus:moved broadcast to all clients\n         bus:position to specific trackers",
      "autoResize": true,
      "lineHeight": 1.25
    },
