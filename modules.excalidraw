    {
      "id": "f8_desc_t",
      "type": "text",
      "x": 4640,
      "y": 2676.875,
      "width": 630,
      "height": 146.25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3s",
      "roundness": null,
      "seed": 200272,
      "version": 1,
      "versionNonce": 200273,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Purpose\n\nIntegrate weather data to adjust\nETA predictions, warn about service\ndisruptions, and provide real-time\nweather info on the passenger app.\n\nFactors: Rain, fog, floods,\nextreme heat, storms",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "f8_desc",
      "originalText": "Purpose\n\nIntegrate weather data to adjust\nETA predictions, warn about service\ndisruptions, and provide real-time\nweather info on the passenger app.\n\nFactors: Rain, fog, floods,\nextreme heat, storms",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "f8_impl",
      "type": "rectangle",
      "x": 5300,
      "y": 2640,
      "width": 1310,
      "height": 220,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "#f1f3f5",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3t",
      "roundness": {
        "type": 3
      },
      "seed": 200274,
      "version": 1,
      "versionNonce": 200275,
      "isDeleted": false,
      "boundElements": [
        {
          "type": "text",
          "id": "f8_impl_t"
        }
      ],
      "updated": 1,
      "link": null,
      "locked": false
    },
    {
      "id": "f8_impl_t",
      "type": "text",
      "x": 5310,
      "y": 2660,
      "width": 1290,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3u",
      "roundness": null,
      "seed": 200276,
      "version": 1,
      "versionNonce": 200277,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Implementation Plan\n\nAPI: OpenWeatherMap or IMD (India Meteorological Dept)\n  Fetch: Current conditions + 3-hour forecast for Coimbatore\n  Cache in Redis (15-min TTL)\n\nETA adjustment:\n  Rain → +20% delay factor    Heavy rain → +40%\n  Fog  → +15% delay factor    Flood alert → route cancelled\n\nMobile UI: Weather badge on map screen\nAdmin: Weather-linked delay notifications",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "f8_impl",
      "originalText": "Implementation Plan\n\nAPI: OpenWeatherMap or IMD (India Meteorological Dept)\n  Fetch: Current conditions + 3-hour forecast for Coimbatore\n  Cache in Redis (15-min TTL)\n\nETA adjustment:\n  Rain → +20% delay factor    Heavy rain → +40%\n  Fog  → +15% delay factor    Flood alert → route cancelled\n\nMobile UI: Weather badge on map screen\nAdmin: Weather-linked delay notifications",
      "autoResize": true,
      "lineHeight": 1.25
    },
