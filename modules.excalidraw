      "link": null,
      "locked": false
    },
    {
      "id": "f10_impl_t",
      "type": "text",
      "x": 5310,
      "y": 3287.5,
      "width": 1290,
      "height": 165,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b48",
      "roundness": null,
      "seed": 200304,
      "version": 1,
      "versionNonce": 200305,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Implementation Plan\n\nPayment gateway: Razorpay (UPI + cards + wallets)\nNew tables:\n  transactions: userId, tripId, amount, method, status, refId\n  tickets: userId, routeId, fromStop, toStop, qrCode, validUntil\n  wallets: userId, balance, lastRecharge\n  passes: userId, type (daily/weekly/monthly), validFrom, validTo\n\nMobile: Payment screen, QR ticket display, wallet balance\nConductor app: QR scanner for ticket validation",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "f10_impl",
      "originalText": "Implementation Plan\n\nPayment gateway: Razorpay (UPI + cards + wallets)\nNew tables:\n  transactions: userId, tripId, amount, method, status, refId\n  tickets: userId, routeId, fromStop, toStop, qrCode, validUntil\n  wallets: userId, balance, lastRecharge\n  passes: userId, type (daily/weekly/monthly), validFrom, validTo\n\nMobile: Payment screen, QR ticket display, wallet balance\nConductor app: QR scanner for ticket validation",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "s3_bg",
      "type": "rectangle",
      "x": 1520,
      "y": 3820,
      "width": 5400,
      "height": 2200,
