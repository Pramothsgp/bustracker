    {
      "id": "m3_tech_t",
      "type": "text",
      "x": 1430,
      "y": 922.5,
      "width": 670,
      "height": 195,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
