    {
      "id": "f3_desc_t",
      "type": "text",
      "x": 4640,
      "y": 962.5,
      "width": 630,
      "height": 195,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
