      "text": "SCHEDULE & TIMETABLE MODULE",
      "fontSize": 20,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "f5_header",
      "originalText": "SCHEDULE & TIMETABLE MODULE",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "f5_desc",
      "type": "rectangle",
      "x": 4630,
      "y": 1630,
      "width": 650,
      "height": 260,
