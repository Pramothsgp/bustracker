      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Purpose\n\nTrack and display bus occupancy\nlevels to help passengers make\ninformed decisions.\n\nLevels: Empty / Low / Medium / High / Full\n\nSources:\n  Driver/conductor manual input\n  Passenger crowdsourcing\n  IoT sensors (future)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "f6_desc",
      "originalText": "Purpose\n\nTrack and display bus occupancy\nlevels to help passengers make\ninformed decisions.\n\nLevels: Empty / Low / Medium / High / Full\n\nSources:\n  Driver/conductor manual input\n  Passenger crowdsourcing\n  IoT sensors (future)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
