    },
    {
      "id": "m7_tech_t",
      "type": "text",
      "x": 1140,
      "y": 2325,
      "width": 960,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1r",
      "roundness": null,
      "seed": 200126,
      "version": 1,
      "versionNonce": 200127,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Dual Strategy\n\nSTATIC DATA (stops):               DYNAMIC DATA (buses):\n  Haversine in JavaScript            Redis GEORADIUS\n  Filter all stops by distance       Native geo-indexing\n  O(n) per query                     O(log n) per query\n  Default: 2km, Max: 10km            Real-time positions\n\nMaps: Leaflet + OSM tiles (web), react-native-maps (mobile)\nFallback: Leaflet WebView for Expo Go (no native modules)",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m7_tech",
      "originalText": "Dual Strategy\n\nSTATIC DATA (stops):               DYNAMIC DATA (buses):\n  Haversine in JavaScript            Redis GEORADIUS\n  Filter all stops by distance       Native geo-indexing\n  O(n) per query                     O(log n) per query\n  Default: 2km, Max: 10km            Real-time positions\n\nMaps: Leaflet + OSM tiles (web), react-native-maps (mobile)\nFallback: Leaflet WebView for Expo Go (no native modules)",
      "autoResize": true,
      "lineHeight": 1.25
    },
