      "version": 1,
      "versionNonce": 200203,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Purpose\n\nProvide operational insights through\naggregated trip data, route performance\nmetrics, and driver statistics.\n\nReports:\n  Daily/weekly/monthly trip summaries\n  Route punctuality & frequency\n  Driver performance scorecards\n  Peak usage heatmaps\n  Fleet utilization rates",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "f3_desc",
      "originalText": "Purpose\n\nProvide operational insights through\naggregated trip data, route performance\nmetrics, and driver statistics.\n\nReports:\n  Daily/weekly/monthly trip summaries\n  Route punctuality & frequency\n  Driver performance scorecards\n  Peak usage heatmaps\n  Fleet utilization rates",
      "autoResize": true,
      "lineHeight": 1.25
    },
