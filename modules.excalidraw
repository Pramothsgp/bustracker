      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Purpose & Overview\n\nManages 146 bus routes across\nCoimbatore city. Each route has\nan ordered sequence of stops.\nSupports search by route number\nor name with case-insensitive\nmatching.",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m2_desc",
      "originalText": "Purpose & Overview\n\nManages 146 bus routes across\nCoimbatore city. Each route has\nan ordered sequence of stops.\nSupports search by route number\nor name with case-insensitive\nmatching.",
      "autoResize": true,
      "lineHeight": 1.25
    },
