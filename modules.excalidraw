    },
    {
      "id": "f1_desc_t",
      "type": "text",
      "x": 4640,
      "y": 260.625,
      "width": 630,
      "height": 178.75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2d",
      "roundness": null,
      "seed": 200170,
      "version": 1,
      "versionNonce": 200171,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Purpose\n\nCalculate estimated arrival time\nfor buses at each upcoming stop.\nCombine real-time position, average\nspeed, historical travel times, and\ntraffic patterns to provide accurate\npassenger-facing predictions.\n\nPriority: HIGH\nComplexity: Medium",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "f1_desc",
      "originalText": "Purpose\n\nCalculate estimated arrival time\nfor buses at each upcoming stop.\nCombine real-time position, average\nspeed, historical travel times, and\ntraffic patterns to provide accurate\npassenger-facing predictions.\n\nPriority: HIGH\nComplexity: Medium",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "f1_approach",
      "type": "rectangle",
      "x": 5300,
      "y": 210,
      "width": 650,
      "height": 280,
      "angle": 0,
      "strokeColor": "#087f5b",
      "backgroundColor": "#e6fcf5",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2e",
      "roundness": {
        "type": 3
      },
      "seed": 200172,
      "version": 1,
      "versionNonce": 200173,
      "isDeleted": false,
      "boundElements": [
        {
          "type": "text",
          "id": "f1_approach_t"
        }
      ],
      "updated": 1,
      "link": null,
      "locked": false
    },
    {
      "id": "f1_approach_t",
      "type": "text",
      "x": 5310,
      "y": 245,
      "width": 630,
      "height": 210,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2f",
      "roundness": null,
      "seed": 200174,
      "version": 1,
      "versionNonce": 200175,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Proposed Algorithm\n\nBASIC (Phase 1):\n  ETA = distance_remaining / avg_speed\n  avg_speed from last N trip_locations\n\nADVANCED (Phase 2):\n  Historical segment times from trip_locations\n  Time-of-day weighting (rush hour factor)\n  Moving average with decay\n\nSMART (Phase 3):\n  ML model trained on historical data\n  Weather + event-based adjustments",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "f1_approach",
      "originalText": "Proposed Algorithm\n\nBASIC (Phase 1):\n  ETA = distance_remaining / avg_speed\n  avg_speed from last N trip_locations\n\nADVANCED (Phase 2):\n  Historical segment times from trip_locations\n  Time-of-day weighting (rush hour factor)\n  Moving average with decay\n\nSMART (Phase 3):\n  ML model trained on historical data\n  Weather + event-based adjustments",
      "autoResize": true,
      "lineHeight": 1.25
    },
