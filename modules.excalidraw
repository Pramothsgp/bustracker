      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Technical Implementation\n\nFiles: route.service.ts, route.routes.ts\nTables: routes, route_stops, stops\n\nDrizzle query with join:\n  db.select().from(routes)\n    .innerJoin(routeStops, eq(...))\n    .innerJoin(stops, eq(...))\n    .orderBy(routeStops.sequence)\n\nSearch: ILIKE '%query%' on number + name",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m2_tech",
      "originalText": "Technical Implementation\n\nFiles: route.service.ts, route.routes.ts\nTables: routes, route_stops, stops\n\nDrizzle query with join:\n  db.select().from(routes)\n    .innerJoin(routeStops, eq(...))\n    .innerJoin(stops, eq(...))\n    .orderBy(routeStops.sequence)\n\nSearch: ILIKE '%query%' on number + name",
      "autoResize": true,
      "lineHeight": 1.25
    },
