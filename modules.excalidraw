      "seed": 200090,
      "version": 1,
      "versionNonce": 200091,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Authentication Flows\n\nDRIVER MAGIC LINK:\n  1. POST /auth/magic-link {email}\n  2. Generate 32-byte hex token\n  3. Store with 15-min expiry\n  4. POST /auth/verify {token}\n  5. Return JWT\n\nADMIN PASSWORD:\n  1. POST /auth/admin/login\n  2. Bun.password.verify (bcrypt)\n  3. Return JWT",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m5_data",
      "originalText": "Authentication Flows\n\nDRIVER MAGIC LINK:\n  1. POST /auth/magic-link {email}\n  2. Generate 32-byte hex token\n  3. Store with 15-min expiry\n  4. POST /auth/verify {token}\n  5. Return JWT\n\nADMIN PASSWORD:\n  1. POST /auth/admin/login\n  2. Bun.password.verify (bcrypt)\n  3. Return JWT",
      "autoResize": true,
      "lineHeight": 1.25
    },
