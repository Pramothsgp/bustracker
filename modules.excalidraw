    {
      "id": "f6_impl_t",
      "type": "text",
      "x": 5310,
      "y": 2010,
      "width": 1290,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
