      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Purpose\n\nCalculate bus fare based on boarding\nand alighting stops. Support multiple\nfare structures: flat rate, distance-\nbased, zone-based, and concession\ncategories.\n\nTypes:\n  Regular / Student / Senior / Pass\n  AC surcharge\n  Peak hour pricing",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "f4_desc",
      "originalText": "Purpose\n\nCalculate bus fare based on boarding\nand alighting stops. Support multiple\nfare structures: flat rate, distance-\nbased, zone-based, and concession\ncategories.\n\nTypes:\n  Regular / Student / Senior / Pass\n  AC surcharge\n  Peak hour pricing",
      "autoResize": true,
      "lineHeight": 1.25
    },
