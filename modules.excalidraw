      "versionNonce": 200095,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Technical Implementation\n\nFiles: auth.service.ts, jwt.ts,\n       auth.routes.ts, auth middleware\nTables: users, magic_link_tokens\n\nMiddleware chain:\n  authenticate() → extract Bearer token\n    → verifyToken() → attach req.user\n  authorize('admin') → check role\n\nStorage:\n  Web: localStorage\n  Mobile: expo-secure-store",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m5_tech",
      "originalText": "Technical Implementation\n\nFiles: auth.service.ts, jwt.ts,\n       auth.routes.ts, auth middleware\nTables: users, magic_link_tokens\n\nMiddleware chain:\n  authenticate() → extract Bearer token\n    → verifyToken() → attach req.user\n  authorize('admin') → check role\n\nStorage:\n  Web: localStorage\n  Mobile: expo-secure-store",
      "autoResize": true,
      "lineHeight": 1.25
    },
