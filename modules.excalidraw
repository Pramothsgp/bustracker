      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Data Retrieval\n\nGET /routes       → All routes (list)\nGET /routes/:id   → Route + ordered stops\nGET /routes/search?q=  → Search by number/name\n\nJoin: routes ← route_stops → stops\nOrdered by: route_stops.sequence ASC\n\nSeed: 146 routes, 5,139 route-stop pairs\nSource: routes.json + route_stops.csv",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m2_data",
      "originalText": "Data Retrieval\n\nGET /routes       → All routes (list)\nGET /routes/:id   → Route + ordered stops\nGET /routes/search?q=  → Search by number/name\n\nJoin: routes ← route_stops → stops\nOrdered by: route_stops.sequence ASC\n\nSeed: 146 routes, 5,139 route-stop pairs\nSource: routes.json + route_stops.csv",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
