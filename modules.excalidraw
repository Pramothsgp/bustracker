    {
      "id": "f2_desc_t",
      "type": "text",
      "x": 4640,
      "y": 612.5,
      "width": 630,
      "height": 195,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2m",
      "roundness": null,
      "seed": 200188,
      "version": 1,
      "versionNonce": 200189,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Purpose\n\nAlert passengers when their bus is\napproaching their stop, when a bus\nstarts on a subscribed route, or\nwhen there are service disruptions.\n\nTypes:\n  Bus approaching (ETA < 5 min)\n  Route started / cancelled\n  Service alerts & delays\n  Geofence entry/exit",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "f2_desc",
      "originalText": "Purpose\n\nAlert passengers when their bus is\napproaching their stop, when a bus\nstarts on a subscribed route, or\nwhen there are service disruptions.\n\nTypes:\n  Bus approaching (ETA < 5 min)\n  Route started / cancelled\n  Service alerts & delays\n  Geofence entry/exit",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "f2_impl",
