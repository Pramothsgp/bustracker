      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Purpose & Overview\n\nTracks live bus positions using\nGPS data from driver devices.\nBroadcasts updates in real-time\nto all connected passengers\nand admin dashboards via\nSocket.IO WebSocket channels.",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m1_desc",
      "originalText": "Purpose & Overview\n\nTracks live bus positions using\nGPS data from driver devices.\nBroadcasts updates in real-time\nto all connected passengers\nand admin dashboards via\nSocket.IO WebSocket channels.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
