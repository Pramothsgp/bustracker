    {
      "id": "m4_tech_t",
      "type": "text",
      "x": 1430,
      "y": 1265,
      "width": 670,
      "height": 210,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
