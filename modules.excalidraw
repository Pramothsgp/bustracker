      "roundness": null,
      "seed": 200076,
      "version": 1,
      "versionNonce": 200077,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Technical Implementation\n\nFiles: trip.service.ts, trip.routes.ts\nTables: trips, trip_locations\n\nConflict check:\n  SELECT * FROM trips\n  WHERE busId = ? AND status = 'active'\n\nTrip location telemetry:\n  Buffered writes every 30 seconds\n  Fields: lat, lng, speed, heading,\n          accuracy, recordedAt\n  Cascade delete on trip removal",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "m4_tech",
      "originalText": "Technical Implementation\n\nFiles: trip.service.ts, trip.routes.ts\nTables: trips, trip_locations\n\nConflict check:\n  SELECT * FROM trips\n  WHERE busId = ? AND status = 'active'\n\nTrip location telemetry:\n  Buffered writes every 30 seconds\n  Fields: lat, lng, speed, heading,\n          accuracy, recordedAt\n  Cascade delete on trip removal",
      "autoResize": true,
      "lineHeight": 1.25
    },
